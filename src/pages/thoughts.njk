---
layout: layout.njk
title: Thoughts
permalink: /thoughts/
---

<section class="content-section">
  <h2>Thoughts</h2>

  {% for post in collections.posts %}
  <article class="blog-entry">
    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <p class="blog-date">{{ post.date | date("YYYY/MM/DD") }}</p>
    <p>{{ post.templateContent | striptags | truncate(200) }}</p>
  </article>
  {% else %}
  <p>Nothing written yet. Stay tuned.</p>
  {% endfor %}
</section>
